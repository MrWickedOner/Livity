# Livity environment variables
# Copy this file to .env and fill in values.
# Only variables prefixed with VITE_ are exposed to the client.

# API base URL. Leave empty for same-origin (production).
# Set to http://localhost:8000 for local development with FastAPI backend.
VITE_API_BASE_URL=

# In development, the backend URL for VITE_API_BASE_URL.
# Example: VITE_API_BASE_URL=http://localhost:8000