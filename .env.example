# Livity Backend — Environment Configuration
#
# Copy this to .env and fill in values.
# Never commit .env to version control.

# --- Server ---
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# --- Database (Neon PostgreSQL + pgvector) ---
DATABASE_URL=postgresql://user:password@host:5432/livity?sslmode=require

# --- OpenAI (for LLM twin conversations + embeddings) ---
OPENAI_API_KEY=sk-...

# --- Anthropic (optional, fallback LLM) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- D-ID (talking-head portrait generation) ---
DID_API_KEY=...
DID_API_URL=https://api.d-id.com

# --- HeyGen (alternative talking-head provider) ---
HEYGEN_API_KEY=...
HEYGEN_API_URL=https://api.heygen.com

# --- Encryption (AES-256 — set by Security Engineer) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=
VAULT_STORAGE_PATH=./data/vault

# --- JWT (auth tokens) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440