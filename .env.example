# Livity Backend — Environment Configuration (copy to .env)
# Never commit .env to version control.

# --- Server ---
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# --- Database (Tiger Cloud PostgreSQL with pgvector) ---
# Leave blank to use local SQLite for dev
DATABASE_URL=postgresql://user:password@host:5432/livity?sslmode=require

# --- Mistral AI (free tier — primary LLM for twin conversations) ---
# Get your API key at https://console.mistral.ai/
MISTRAL_API_KEY=

# --- OpenAI (fallback LLM + embeddings) ---
OPENAI_API_KEY=sk-...

# --- Anthropic (fallback LLM) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- D-ID (talking-head portrait generation) ---
DID_API_KEY=
DID_API_URL=https://api.d-id.com

# --- HeyGen (alternative talking-head provider) ---
HEYGEN_API_KEY=
HEYGEN_API_URL=https://api.heygen.com

# --- Encryption (AES-256 — set by Security Engineer) ---
ENCRYPTION_KEY=
VAULT_STORAGE_PATH=./data/vault

# --- JWT (auth tokens) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440